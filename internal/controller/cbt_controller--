func (ctrl *cbtController) calculateMCQScore(questionID uint, selectedOptionIDs []uint, weight float64) float64 {
	options, err := ctrl.repo.GetOptionsByQuestionID(questionID)
	if err != nil {
		return 0
	}

	var correctOptionID *uint
	for _, opt := range options {
		if opt.IsCorrect {
			correctOptionID = &opt.OptionID
			break
		}
	}

	if correctOptionID == nil {
		return 0
	}

	for _, selectedID := range selectedOptionIDs {
		if selectedID == *correctOptionID {
			return weight
		}
	}

	return 0
}

func (ctrl *cbtController) calculateShortAnswerScore(questionID uint, answer string, weight float64) float64 {
	validAnswers, err := ctrl.repo.GetShortAnswersByQuestionID(questionID)
	if err != nil {
		return 0
	}

	for _, va := range validAnswers {
		if va.CaseSensitive {
			if answer == va.ValidAnswer {
				return weight
			}
		} else {
			if strings.EqualFold(answer, va.ValidAnswer) {
				return weight
			}
		}
	}

	return 0
}

func (ctrl *cbtController) calculateMatchingScore(questionID uint, studentAnswers map[string]string, weight float64) float64 {
	matchingPairs, err := ctrl.repo.GetMatchingPairsByQuestionID(questionID)
	if err != nil {
		return 0
	}

	correctCount := 0
	for _, pair := range matchingPairs {
		studentRight, exists := studentAnswers[fmt.Sprintf("%d", pair.MatchingID)]
		if exists && studentRight == pair.RightText {
			correctCount++
		}
	}

	if len(matchingPairs) > 0 {
		return (float64(correctCount) / float64(len(matchingPairs))) * weight
	}

	return 0
}

func timeNowPtr() *time.Time {
	t := time.Now()
	return &t
}

