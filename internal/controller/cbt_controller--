func (ctrl *cbtController) SubmitAssessment(c *gin.Context) {
	var req dto.SubmitAssessmentRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	attempt, err := ctrl.repo.GetAttemptByID(req.AttemptID)
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "attempt not found"})
		return
	}

	if attempt.Status != "IN_PROGRESS" && attempt.Status != "PAUSED" {
		c.JSON(http.StatusBadRequest, gin.H{"error": "attempt sudah disubmit sebelumnya"})
		return
	}

	assessment, err := ctrl.repo.GetAssessmentByID(attempt.AssessmentID)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	attemptQuestions, err := ctrl.repo.GetAttemptQuestions(req.AttemptID)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	var totalScore float64
	var totalWeight int

	for _, aq := range attemptQuestions {
		totalWeight += aq.WeightSnapshot

		if aq.AutoScore != nil {
			totalScore += *aq.AutoScore
		}
	}

	finalScore := (totalScore / float64(totalWeight)) * 100

	status := "COMPLETED"
	hasEssay := false

	for _, aq := range attemptQuestions {
		if aq.QuestionTypeSnapshot == "ESSAY" && aq.TeacherScore == nil {
			hasEssay = true
			break
		}
	}

	if hasEssay {
		status = "WAITING_REVIEW"
	}

	submittedAt := time.Now()
	isPassed := finalScore >= assessment.PassingScore

	attempt.Status = status
	attempt.SubmittedAt = &submittedAt
	attempt.FinalScore = &finalScore
	attempt.IsPassed = &isPassed

	err = ctrl.repo.UpdateAttempt(attempt)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	log := &model.ToAutosaveLog{
		AttemptID: req.AttemptID,
		Action:    "SUBMIT",
	}
	ctrl.repo.CreateAutosaveLog(log)

	c.JSON(http.StatusOK, gin.H{"message": "assessment submitted successfully"})
}

