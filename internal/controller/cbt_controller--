func (ctrl *cbtController) CreateQuestion(c *gin.Context) {
	var req dto.CreateQuestionRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	userID, _ := c.Get("user_id")
	guru, err := ctrl.getGuruByUserID(userID.(int))
	if err != nil {
		c.JSON(http.StatusUnauthorized, gin.H{"error": "guru tidak ditemukan"})
		return
	}

	question := &model.ToQuestion{
		BankID:          req.BankID,
		QuestionType:    req.QuestionType,
		QuestionText:    req.QuestionText,
		Explanation:     req.Explanation,
		DifficultyLevel: req.DifficultyLevel,
		CreatedBy:       int(guru.GuruID),
	}

	err = ctrl.repo.CreateQuestion(question)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	switch req.QuestionType {
	case "MCQ", "MULTI_MCQ", "TRUE_FALSE":
		options := make([]model.ToQuestionOption, len(req.Options))
		for i, opt := range req.Options {
			options[i] = model.ToQuestionOption{
				QuestionID:  question.QuestionID,
				OptionLabel: opt.Label,
				OptionText:  opt.Text,
				IsCorrect:   opt.IsCorrect,
				SortOrder:   opt.SortOrder,
			}
		}
		err = ctrl.repo.CreateOptions(options)

	case "SHORT_ANSWER":
		answers := make([]model.ToQuestionShortAnswer, len(req.ValidAnswers))
		for i, ans := range req.ValidAnswers {
			answers[i] = model.ToQuestionShortAnswer{
				QuestionID:    question.QuestionID,
				ValidAnswer:   ans,
				CaseSensitive: req.CaseSensitive,
			}
		}
		err = ctrl.repo.CreateShortAnswers(answers)

	case "MATCHING":
		pairs := make([]model.ToQuestionMatching, len(req.MatchingPairs))
		for i, pair := range req.MatchingPairs {
			pairs[i] = model.ToQuestionMatching{
				QuestionID: question.QuestionID,
				LeftText:   pair.LeftText,
				RightText:  pair.RightText,
				PairOrder:  pair.PairOrder,
			}
		}
		err = ctrl.repo.CreateMatchingPairs(pairs)
	}

	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusCreated, dto.QuestionResponse{
		QuestionID:      question.QuestionID,
		BankID:          question.BankID,
		QuestionType:    question.QuestionType,
		QuestionText:    question.QuestionText,
		Explanation:     question.Explanation,
		DifficultyLevel: question.DifficultyLevel,
		CreatedAt:       question.CreatedAt,
	})
}

