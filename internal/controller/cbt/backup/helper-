func (ctrl *cbtController) getStudentName(studentID int) string {
	var siswa model.Siswa
	err := ctrl.db.Where("siswa_id = ?", studentID).First(&siswa).Error
	if err != nil {
		return ""
	}
	if siswa.SiswaNama != nil {
		return *siswa.SiswaNama
	}
	return ""
}

