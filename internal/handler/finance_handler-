type FinanceHandler interface {
	// Fee Templates
	GetAllFeeTemplates(c *gin.Context)
	GetFeeTemplateByID(c *gin.Context)
	CreateFeeTemplate(c *gin.Context)
	UpdateFeeTemplate(c *gin.Context)
	DeleteFeeTemplate(c *gin.Context)

	// Invoices
	GetAllInvoices(c *gin.Context)
	GetInvoiceByID(c *gin.Context)
	CreateInvoice(c *gin.Context)
	UpdateInvoice(c *gin.Context)
	DeleteInvoice(c *gin.Context)
	PublishInvoice(c *gin.Context)
	CancelInvoice(c *gin.Context)
	AddInvoiceItem(c *gin.Context)
	UpdateInvoiceItem(c *gin.Context)
	RemoveInvoiceItem(c *gin.Context)
	AddInvoiceAdjustment(c *gin.Context)
	UpdateInvoiceAdjustment(c *gin.Context)
	RemoveInvoiceAdjustment(c *gin.Context)

	// Payments
	GetAllPayments(c *gin.Context)
	GetPaymentByID(c *gin.Context)
	CreatePayment(c *gin.Context)
	DeletePayment(c *gin.Context)
}

type financeHandler struct {
	financeController controller.FinanceController
}

func NewFinanceHandler(financeController controller.FinanceController) FinanceHandler {
	return &financeHandler{financeController: financeController}
}

// ==================== FEE TEMPLATES ====================

func (h *financeHandler) GetAllFeeTemplates(c *gin.Context) {
	isActiveStr := c.Query("is_active")
	var isActive *int8
	if isActiveStr != "" {
		val, err := strconv.ParseInt(isActiveStr, 10, 8)
		if err == nil {
			active := int8(val)
			isActive = &active
		}
	}

	result, err := h.financeController.GetAllFeeTemplates(isActive)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}
	c.JSON(http.StatusOK, result)
}

func (h *financeHandler) GetFeeTemplateByID(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	result, err := h.financeController.GetFeeTemplateByID(id)
	if err != nil {
