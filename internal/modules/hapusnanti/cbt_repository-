type CBTRepository interface {
	// Assessment
	CreateAssessment(assessment *model.ToAssessment) error
	GetAssessmentByID(id uint) (*model.ToAssessment, error)
	GetAssessmentsByType(assessmentType string, page, limit int) ([]model.ToAssessment, int64, error)
	UpdateAssessment(assessment *model.ToAssessment) error
	DeleteAssessment(id uint) error

	// Assessment Question
	AddQuestionToAssessment(assessmentQuestion *model.ToAssessmentQuestion) error
	GetAssessmentQuestions(assessmentID uint) ([]model.ToAssessmentQuestion, error)
	RemoveQuestionFromAssessment(assessmentID, questionID uint) error

	// Assessment Student
	AddStudentToAssessment(assessmentStudent *model.ToAssessmentStudent) error
	AddStudentsToAssessment(assessmentStudents []model.ToAssessmentStudent) error
	GetAssessmentStudents(assessmentID uint) ([]model.ToAssessmentStudent, error)
	GetAssessmentStudentByID(assessmentID uint, studentID int) (*model.ToAssessmentStudent, error)
	RemoveStudentFromAssessment(assessmentID, studentID uint) error

	// Bank Soal
	CreateBank(bank *model.ToQuestionBank) error
	GetBankByID(id uint) (*model.ToQuestionBank, error)
	GetAllBanks() ([]model.ToQuestionBank, error)

	// Question
	CreateQuestion(question *model.ToQuestion) error
	GetQuestionByID(id uint) (*model.ToQuestion, error)
	GetQuestionsByBank(bankID uint) ([]model.ToQuestion, error)
	GetQuestionsByIDs(ids []uint) ([]model.ToQuestion, error)
	UpdateQuestion(question *model.ToQuestion) error
	DeleteQuestion(id uint) error

	// Question Option
	CreateOptions(options []model.ToQuestionOption) error
	GetOptionsByQuestionID(questionID uint) ([]model.ToQuestionOption, error)

	// Short Answer
	CreateShortAnswers(answers []model.ToQuestionShortAnswer) error
	GetShortAnswersByQuestionID(questionID uint) ([]model.ToQuestionShortAnswer, error)

	// Matching
	CreateMatchingPairs(pairs []model.ToQuestionMatching) error
	GetMatchingPairsByQuestionID(questionID uint) ([]model.ToQuestionMatching, error)

	// Attempt
	CreateAttempt(attempt *model.ToAttempt) error
	GetAttemptByID(id uint) (*model.ToAttempt, error)
	GetActiveAttempt(assessmentID uint, studentID int) (*model.ToAttempt, error)
	GetAttemptsByStudent(studentID int, page, limit int) ([]model.ToAttempt, int64, error)
	UpdateAttempt(attempt *model.ToAttempt) error

	// Attempt Question
	CreateAttemptQuestions(questions []model.ToAttemptQuestion) error
	GetAttemptQuestions(attemptID uint) ([]model.ToAttemptQuestion, error)
	GetAttemptQuestionByID(id uint) (*model.ToAttemptQuestion, error)
	UpdateAttemptQuestion(question *model.ToAttemptQuestion) error

	// Autosave Log
	CreateAutosaveLog(log *model.ToAutosaveLog) error

	// Bank Soal - tambahan
	GetBanks(search string, page, limit int) ([]model.ToQuestionBank, int64, error)
	UpdateBank(bank *model.ToQuestionBank) error
	DeleteBank(id uint) error
	CountQuestionsByBankID(bankID uint) (int64, error)
	GetQuestionsByBankID(bankID uint, page, limit int) ([]model.ToQuestion, int64, error)
}

type cbtRepository struct {
	db *gorm.DB
}

func NewCBTRepository(db *gorm.DB) CBTRepository {
	return &cbtRepository{db: db}
}

// ============================================
// ASSESSMENT IMPLEMENTATION
// ============================================

func (r *cbtRepository) CreateAssessment(assessment *model.ToAssessment) error {
	return r.db.Create(assessment).Error
}

func (r *cbtRepository) GetAssessmentByID(id uint) (*model.ToAssessment, error) {
	var assessment model.ToAssessment
	err := r.db.Where("assessment_id = ? AND deleted_at IS NULL", id).First(&assessment).Error
	if err != nil {
		return nil, err
	}
	return &assessment, nil
}

func (r *cbtRepository) GetAssessmentsByType(assessmentType string, page, limit int) ([]model.ToAssessment, int64, error) {
	var assessments []model.ToAssessment
	var total int64

	query := r.db.Model(&model.ToAssessment{}).Where("deleted_at IS NULL")
	if assessmentType != "" {
		query = query.Where("type = ?", assessmentType)
	}

	err := query.Count(&total).Error
	if err != nil {
		return nil, 0, err
	}

	offset := (page - 1) * limit
	err = query.Order("created_at DESC").Offset(offset).Limit(limit).Find(&assessments).Error
	if err != nil {
		return nil, 0, err
	}

	return assessments, total, nil
}

func (r *cbtRepository) UpdateAssessment(assessment *model.ToAssessment) error {
	return r.db.Save(assessment).Error
}

func (r *cbtRepository) DeleteAssessment(id uint) error {
	return r.db.Model(&model.ToAssessment{}).Where("assessment_id = ?", id).Update("deleted_at", time.Now()).Error
}

