func (r *cbtRepository) GetBanks(search string, page, limit int) ([]model.ToQuestionBank, int64, error) {
	var banks []model.ToQuestionBank
	var total int64

	query := r.db.Model(&model.ToQuestionBank{}).Where("deleted_at IS NULL")

	if search != "" {
		query = query.Where("bank_name LIKE ? OR kd_mapel LIKE ?",
			"%"+search+"%", "%"+search+"%")
	}

	// Hitung total
	if err := query.Count(&total).Error; err != nil {
		return nil, 0, err
	}

	// Pagination
	offset := (page - 1) * limit
	err := query.
		Preload("Mapel"). // biar dapet nama mapel
		Preload("Kelas"). // biar dapet nama kelas
		Preload("User").  // biar dapet nama pembuat
		Order("created_at DESC").
		Offset(offset).
		Limit(limit).
		Find(&banks).Error

	return banks, total, err
}

func (r *cbtRepository) UpdateBank(bank *model.ToQuestionBank) error {
	return r.db.Save(bank).Error
}

func (r *cbtRepository) DeleteBank(id uint) error {
	return r.db.Model(&model.ToQuestionBank{}).
		Where("bank_id = ?", id).
		Update("deleted_at", time.Now()).Error
}

func (r *cbtRepository) CountQuestionsByBankID(bankID uint) (int64, error) {
	var count int64
	err := r.db.Model(&model.ToQuestion{}).
		Where("bank_id = ? AND deleted_at IS NULL", bankID).
		Count(&count).Error
	return count, err
}

func (r *cbtRepository) GetQuestionsByBankID(bankID uint, page, limit int) ([]model.ToQuestion, int64, error) {
	var questions []model.ToQuestion
	var total int64

	query := r.db.Model(&model.ToQuestion{}).
		Where("bank_id = ? AND deleted_at IS NULL", bankID)

	if err := query.Count(&total).Error; err != nil {
		return nil, 0, err
	}

	offset := (page - 1) * limit
	err := query.
		Offset(offset).
		Limit(limit).
		Order("created_at DESC").
		Find(&questions).Error

	return questions, total, err
}
