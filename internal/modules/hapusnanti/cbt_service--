func (s *cbtService) calculateMCQScore(questionID uint, selectedOptionIDs []uint, weight float64) float64 {
	options, err := s.repo.GetOptionsByQuestionID(questionID)
	if err != nil {
		return 0
	}

	// Cari opsi yang benar
	var correctOptionID *uint
	for _, opt := range options {
		if opt.IsCorrect {
			correctOptionID = &opt.OptionID
			break
		}
	}

	if correctOptionID == nil {
		return 0
	}

	// Cek apakah jawaban benar
	for _, selectedID := range selectedOptionIDs {
		if selectedID == *correctOptionID {
			return weight
		}
	}

	return 0
}

func (s *cbtService) calculateShortAnswerScore(questionID uint, answer string, weight float64) float64 {
	validAnswers, err := s.repo.GetShortAnswersByQuestionID(questionID)
	if err != nil {
		return 0
	}

	for _, va := range validAnswers {
		if va.CaseSensitive {
			if answer == va.ValidAnswer {
				return weight
			}
		} else {
			if strings.EqualFold(answer, va.ValidAnswer) {
				return weight
			}
		}
	}

	return 0
}

func (s *cbtService) calculateMatchingScore(questionID uint, studentAnswers map[string]string, weight float64) float64 {
	matchingPairs, err := s.repo.GetMatchingPairsByQuestionID(questionID)
	if err != nil {
		return 0
	}

	correctCount := 0
	for _, pair := range matchingPairs {
		// Cek apakah jawaban siswa sesuai
		studentRight, exists := studentAnswers[fmt.Sprintf("%d", pair.MatchingID)]
		if exists && studentRight == pair.RightText {
			correctCount++
		}
	}

	// Prorata: (jawaban benar / total pasangan) * bobot
	if len(matchingPairs) > 0 {
		return (float64(correctCount) / float64(len(matchingPairs))) * weight
	}

	return 0
}

func timeNowPtr() *time.Time {
	t := time.Now()
	return &t
}
