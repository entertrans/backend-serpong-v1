func (s *cbtService) SubmitAnswer(req *dto.SubmitAnswerRequest) error {
	attemptQuestion, err := s.repo.GetAttemptQuestionByID(req.AttemptQuestionID)
	if err != nil {
		return err
	}

	if attemptQuestion.AttemptID != req.AttemptID {
		return errors.New("attempt tidak cocok")
	}

	// Update jawaban berdasarkan tipe soal
	switch attemptQuestion.QuestionTypeSnapshot {
	case "MCQ", "MULTI_MCQ", "TRUE_FALSE":
		idsJSON, _ := json.Marshal(req.SelectedOptionIDs)
		idsStr := string(idsJSON)
		attemptQuestion.SelectedOptionIDs = &idsStr

		// Hitung auto score untuk MCQ
		autoScore := s.calculateMCQScore(attemptQuestion.OriginalQuestionID, req.SelectedOptionIDs, float64(attemptQuestion.WeightSnapshot))
		attemptQuestion.AutoScore = &autoScore

	case "SHORT_ANSWER":
		attemptQuestion.AnswerText = req.AnswerText

		// Hitung auto score untuk short answer
		autoScore := s.calculateShortAnswerScore(attemptQuestion.OriginalQuestionID, *req.AnswerText, float64(attemptQuestion.WeightSnapshot))
		attemptQuestion.AutoScore = &autoScore

	case "MATCHING":
		matchingJSON, _ := json.Marshal(req.MatchingAnswer)
		matchingStr := string(matchingJSON)
		attemptQuestion.MatchingAnswerJSON = &matchingStr

		// Hitung auto score untuk matching
		autoScore := s.calculateMatchingScore(attemptQuestion.OriginalQuestionID, req.MatchingAnswer, float64(attemptQuestion.WeightSnapshot))
		attemptQuestion.AutoScore = &autoScore

	case "ESSAY":
		if req.IsFinalSubmit {
			attemptQuestion.EssayAnswer = req.EssayAnswer
			attemptQuestion.EssayLastSavedAt = timeNowPtr()
		}
	}

	err = s.repo.UpdateAttemptQuestion(attemptQuestion)
	if err != nil {
		return err
	}

	// Update last activity
	attempt, _ := s.repo.GetAttemptByID(req.AttemptID)
	if attempt != nil {
		attempt.LastActivityAt = time.Now()
		s.repo.UpdateAttempt(attempt)
	}

	return nil
}

func (s *cbtService) SubmitEssayDraft(req *dto.SubmitEssayDraftRequest) error {
	attemptQuestion, err := s.repo.GetAttemptQuestionByID(req.AttemptQuestionID)
	if err != nil {
		return err
	}

	if attemptQuestion.AttemptID != req.AttemptID {
		return errors.New("attempt tidak cocok")
	}

	if attemptQuestion.QuestionTypeSnapshot != "ESSAY" {
		return errors.New("hanya essay yang memiliki draft")
	}

	// Simpan draft, BUKAN jawaban final
	// Untuk draft, kita simpan di field terpisah atau update essay_answer dengan flag
	// Karena di model tidak ada field draft terpisah, kita update essay_answer tapi dengan catatan
	attemptQuestion.EssayAnswer = &req.EssayDraft
	attemptQuestion.EssayLastSavedAt = timeNowPtr()

	err = s.repo.UpdateAttemptQuestion(attemptQuestion)
	if err != nil {
		return err
	}

	// Log autosave
	log := &model.ToAutosaveLog{
		AttemptID:         req.AttemptID,
		AttemptQuestionID: &req.AttemptQuestionID,
		Action:            "AUTO_SAVE_DRAFT",
	}
	s.repo.CreateAutosaveLog(log)

	return nil
}

func (s *cbtService) SubmitAssessment(attemptID uint) error {
	attempt, err := s.repo.GetAttemptByID(attemptID)
	if err != nil {
		return err
	}

	if attempt.Status != "IN_PROGRESS" && attempt.Status != "PAUSED" {
		return errors.New("attempt sudah disubmit sebelumnya")
	}

	attemptQuestions, err := s.repo.GetAttemptQuestions(attemptID)
	if err != nil {
		return err
	}

	// Hitung ulang semua nilai otomatis
	var totalScore float64
	var totalWeight int

	for _, aq := range attemptQuestions {
		totalWeight += aq.WeightSnapshot

		if aq.AutoScore != nil {
			totalScore += *aq.AutoScore
		}
	}

	finalScore := (totalScore / float64(totalWeight)) * 100

	// Tentukan status akhir
	status := "COMPLETED"
	hasEssay := false

	for _, aq := range attemptQuestions {
		if aq.QuestionTypeSnapshot == "ESSAY" && aq.TeacherScore == nil {
			hasEssay = true
			break
		}
	}

	if hasEssay {
		status = "WAITING_REVIEW"
	}

	submittedAt := time.Now()
	isPassed := finalScore >= attempt.PassingScore

	attempt.Status = status
	attempt.SubmittedAt = &submittedAt
	attempt.FinalScore = &finalScore
	attempt.IsPassed = &isPassed

	err = s.repo.UpdateAttempt(attempt)
	if err != nil {
		return err
	}

	// Log submit
	log := &model.ToAutosaveLog{
		AttemptID: attemptID,
		Action:    "SUBMIT",
	}
	s.repo.CreateAutosaveLog(log)

	return nil
}

// ============================================
// REVIEW SERVICE
// ============================================

func (s *cbtService) ReviewEssay(req *dto.ReviewEssayRequest, teacherID int) error {
	attemptQuestion, err := s.repo.GetAttemptQuestionByID(req.AttemptQuestionID)
	if err != nil {
		return err
	}

	if attemptQuestion.AttemptID != req.AttemptID {
		return errors.New("attempt tidak cocok")
	}

	if attemptQuestion.QuestionTypeSnapshot != "ESSAY" {
		return errors.New("hanya essay yang bisa direview")
	}

	attemptQuestion.TeacherScore = &req.TeacherScore
	attemptQuestion.TeacherNote = &req.TeacherNote
	attemptQuestion.ReviewStatus = "APPROVED"
	attemptQuestion.ReviewedAt = timeNowPtr()
	attemptQuestion.ReviewedBy = &teacherID

	err = s.repo.UpdateAttemptQuestion(attemptQuestion)
	if err != nil {
		return err
	}

	// Hitung ulang final score
	attempt, err := s.repo.GetAttemptByID(req.AttemptID)
	if err != nil {
		return err
	}

	attemptQuestions, err := s.repo.GetAttemptQuestions(req.AttemptID)
	if err != nil {
		return err
	}

	var totalScore float64
	var totalWeight int

	for _, aq := range attemptQuestions {
		totalWeight += aq.WeightSnapshot

		if aq.AutoScore != nil {
			totalScore += *aq.AutoScore
		}
		if aq.TeacherScore != nil {
			totalScore += *aq.TeacherScore
		}
	}

	finalScore := (totalScore / float64(totalWeight)) * 100
	isPassed := finalScore >= attempt.PassingScore

	// Cek apakah masih ada essay yang belum direview
	hasPendingEssay := false
	for _, aq := range attemptQuestions {
		if aq.QuestionTypeSnapshot == "ESSAY" && aq.ReviewStatus == "PENDING" {
			hasPendingEssay = true
			break
		}
	}

	if !hasPendingEssay {
		attempt.Status = "COMPLETED"
	}

	attempt.FinalScore = &finalScore
	attempt.IsPassed = &isPassed

	return s.repo.UpdateAttempt(attempt)
}

func (s *cbtService) OverrideScore(req *dto.OverrideScoreRequest, teacherID int) error {
	attempt, err := s.repo.GetAttemptByID(req.AttemptID)
	if err != nil {
		return err
	}

	oldScore := attempt.FinalScore

	attempt.IsOverride = true
	attempt.OverrideScore = &req.NewScore
	attempt.OverrideReason = &req.Reason
	attempt.OverriddenBy = &teacherID
	attempt.OverriddenAt = timeNowPtr()
	attempt.FinalScore = &req.NewScore
	attempt.IsPassed = &[]bool{req.NewScore >= attempt.PassingScore}[0]

	return s.repo.UpdateAttempt(attempt)
}

