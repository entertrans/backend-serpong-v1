type CBTService interface {
	// Assessment
	CreateAssessment(req *dto.CreateAssessmentRequest, teacherID int) (*dto.AssessmentResponse, error)
	GetAssessmentByID(id uint) (*dto.AssessmentDetailResponse, error)
	GetAssessments(assessmentType string, page, limit int) ([]dto.AssessmentResponse, int64, error)

	// Bank & Question
	CreateBank(req *dto.CreateBankRequest, teacherID int) (*dto.BankResponse, error)
	CreateQuestion(req *dto.CreateQuestionRequest, teacherID int) (*dto.QuestionResponse, error)

	// Enrollment
	EnrollStudents(assessmentID uint, studentIDs []int) error

	// Attempt
	StartAttempt(studentID int, req *dto.StartAttemptRequest) (*dto.StartAttemptResponse, error)
	ResumeAttempt(attemptID uint) (*dto.ResumeAttemptResponse, error)

	// Answer
	SubmitAnswer(req *dto.SubmitAnswerRequest) error
	SubmitEssayDraft(req *dto.SubmitEssayDraftRequest) error
	SubmitAssessment(attemptID uint) error

	// Review
	ReviewEssay(req *dto.ReviewEssayRequest, teacherID int) error
	OverrideScore(req *dto.OverrideScoreRequest, teacherID int) error
}

type cbtService struct {
	repo repository.CBTRepository
}

func NewCBTService(repo repository.CBTRepository) CBTService {
	return &cbtService{repo: repo}
}

// ============================================
// ASSESSMENT SERVICE
// ============================================

func (s *cbtService) CreateAssessment(req *dto.CreateAssessmentRequest, teacherID int) (*dto.AssessmentResponse, error) {
	// Validasi jumlah soal
	if len(req.QuestionIDs) != len(req.Weights) {
		return nil, errors.New("jumlah question_ids dan weights harus sama")
	}

	// Hitung total bobot
	totalWeight := 0
	for _, w := range req.Weights {
		totalWeight += w
	}
	if totalWeight != 100 {
		return nil, errors.New("total bobot harus 100")
	}

	// Validasi tanggal
	if req.ActiveFrom.After(req.ActiveUntil) {
		return nil, errors.New("active_from harus sebelum active_until")
	}

	// Buat assessment
	assessment := &model.ToAssessment{
		Title:                req.Title,
		Description:          req.Description,
		Type:                 req.Type,
		AutoEnrollClassID:    req.AutoEnrollClassID,
		DurationMinutes:      req.DurationMinutes,
		IsRandomQuestion:     req.IsRandomQuestion,
		IsRandomOption:       req.IsRandomOption,
		TotalQuestionDisplay: req.TotalQuestionDisplay,
		PassingScore:         req.PassingScore,
		ActiveFrom:           req.ActiveFrom,
		ActiveUntil:          req.ActiveUntil,
		Instruction:          req.Instruction,
		CreatedBy:            teacherID,
	}

	err := s.repo.CreateAssessment(assessment)
	if err != nil {
		return nil, err
	}

	// Tambahkan soal ke assessment
	for i, questionID := range req.QuestionIDs {
		assessmentQuestion := &model.ToAssessmentQuestion{
			AssessmentID: assessment.AssessmentID,
			QuestionID:   questionID,
			Weight:       req.Weights[i],
		}
		err = s.repo.AddQuestionToAssessment(assessmentQuestion)
		if err != nil {
			return nil, err
		}
	}

	// Auto enroll jika ada auto_enroll_class_id
	if req.AutoEnrollClassID != nil {
		// TODO: Ambil daftar siswa berdasarkan class_id dari tabel tbl_siswa
		// Untuk sementara, ini hanya placeholder
	}

	return &dto.AssessmentResponse{
		AssessmentID:         assessment.AssessmentID,
		Title:                assessment.Title,
		Description:          assessment.Description,
		Type:                 assessment.Type,
		DurationMinutes:      assessment.DurationMinutes,
		IsRandomQuestion:     assessment.IsRandomQuestion,
		IsRandomOption:       assessment.IsRandomOption,
		TotalQuestionDisplay: assessment.TotalQuestionDisplay,
		PassingScore:         assessment.PassingScore,
		ActiveFrom:           assessment.ActiveFrom,
		ActiveUntil:          assessment.ActiveUntil,
		Instruction:          assessment.Instruction,
		CreatedBy:            assessment.CreatedBy,
		CreatedAt:            assessment.CreatedAt,
		TotalQuestions:       len(req.QuestionIDs),
	}, nil
}

func (s *cbtService) GetAssessmentByID(id uint) (*dto.AssessmentDetailResponse, error) {
	assessment, err := s.repo.GetAssessmentByID(id)
	if err != nil {
		return nil, err
	}

	// Ambil soal-soal assessment
	assessmentQuestions, err := s.repo.GetAssessmentQuestions(id)
	if err != nil {
		return nil, err
	}

	questions := make([]dto.AssessmentQuestionDetail, 0)
	for _, aq := range assessmentQuestions {
		question, err := s.repo.GetQuestionByID(aq.QuestionID)
		if err != nil {
			continue
		}
		questions = append(questions, dto.AssessmentQuestionDetail{
			AssessmentQuestionID: aq.AssessmentQuestionID,
			QuestionID:           question.QuestionID,
			QuestionText:         question.QuestionText,
			QuestionType:         question.QuestionType,
			Weight:               aq.Weight,
			FixedOrder:           aq.FixedOrder,
		})
	}

	// Ambil siswa yang terdaftar
	assessmentStudents, err := s.repo.GetAssessmentStudents(id)
	if err != nil {
		return nil, err
	}

	students := make([]dto.AssessmentStudentDetail, 0)
	for _, as := range assessmentStudents {
		// TODO: Ambil nama siswa dari tbl_siswa
		students = append(students, dto.AssessmentStudentDetail{
			AssessmentStudentID: as.AssessmentStudentID,
			StudentID:           as.StudentID,
			EnrolledAt:          as.EnrolledAt,
		})
	}

	return &dto.AssessmentDetailResponse{
		AssessmentResponse: dto.AssessmentResponse{
			AssessmentID:     assessment.AssessmentID,
			Title:            assessment.Title,
			Description:      assessment.Description,
			Type:             assessment.Type,
			DurationMinutes:  assessment.DurationMinutes,
			IsRandomQuestion: assessment.IsRandomQuestion,
			IsRandomOption:   assessment.IsRandomOption,
			PassingScore:     assessment.PassingScore,
			ActiveFrom:       assessment.ActiveFrom,
			ActiveUntil:      assessment.ActiveUntil,
			Instruction:      assessment.Instruction,
			CreatedBy:        assessment.CreatedBy,
			CreatedAt:        assessment.CreatedAt,
			TotalQuestions:   len(questions),
			TotalStudents:    len(students),
		},
		Questions: questions,
		Students:  students,
	}, nil
}

func (s *cbtService) GetAssessments(assessmentType string, page, limit int) ([]dto.AssessmentResponse, int64, error) {
	assessments, total, err := s.repo.GetAssessmentsByType(assessmentType, page, limit)
	if err != nil {
		return nil, 0, err
	}

	result := make([]dto.AssessmentResponse, len(assessments))
	for i, a := range assessments {
		// Hitung jumlah soal
		questions, _ := s.repo.GetAssessmentQuestions(a.AssessmentID)
		students, _ := s.repo.GetAssessmentStudents(a.AssessmentID)

		result[i] = dto.AssessmentResponse{
			AssessmentID:         a.AssessmentID,
			Title:                a.Title,
			Description:          a.Description,
			Type:                 a.Type,
			DurationMinutes:      a.DurationMinutes,
			IsRandomQuestion:     a.IsRandomQuestion,
			IsRandomOption:       a.IsRandomOption,
			TotalQuestionDisplay: a.TotalQuestionDisplay,
			PassingScore:         a.PassingScore,
			ActiveFrom:           a.ActiveFrom,
			ActiveUntil:          a.ActiveUntil,
			Instruction:          a.Instruction,
			CreatedBy:            a.CreatedBy,
			CreatedAt:            a.CreatedAt,
			TotalQuestions:       len(questions),
			TotalStudents:        len(students),
		}
	}

	return result, total, nil
}

