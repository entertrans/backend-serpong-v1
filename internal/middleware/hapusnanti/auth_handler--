// internal/handler/auth_handler.go
func (h *authHandler) RegisterGuru(c *gin.Context) {
	var req RegisterGuruRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		response.SendErrorResponse(c, http.StatusBadRequest, err.Error())
		return
	}

	// Verifikasi kode unik atau approval token (opsional)
	// Misalnya: cek NIP terdaftar di database guru terlebih dahulu

	userDTO, err := h.authController.CreateGuru(req.NIP, req.Name, req.Email)
	if err != nil {
		response.SendErrorResponse(c, http.StatusConflict, err.Error())
		return
	}

	response.SendResponse(c, http.StatusCreated, "Guru registered successfully", userDTO)
}

type RegisterGuruRequest struct {
	NIP   string `json:"nip" binding:"required"`
	Name  string `json:"name" binding:"required"`
	Email string `json:"email"`
}
